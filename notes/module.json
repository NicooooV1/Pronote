{
    "key": "notes",
    "version": "1.0.0",
    "name": { "fr": "Notes", "en": "Grades" },
    "description": { "fr": "Gestion des notes et moyennes", "en": "Grade and average management" },
    "icon": "fas fa-chart-bar",
    "category": "scolaire",
    "core": false,
    "requires_php": ">=8.0",
    "dependencies": [],
    "permissions": {
        "view": { "default_roles": ["*"] },
        "manage": { "default_roles": ["administrateur", "professeur", "vie_scolaire"] },
        "edit": { "default_roles": ["administrateur", "professeur"] },
        "delete": { "default_roles": ["administrateur"] },
        "export": { "default_roles": ["administrateur", "vie_scolaire"] }
    },
    "routes": {
        "main": "notes.php",
        "api": "api/actions.php"
    },
    "widgets": [
        {
            "key": "dernieres_notes",
            "name": { "fr": "Dernières notes", "en": "Latest grades" },
            "description": { "fr": "Notes les plus récentes", "en": "Most recent grades" },
            "type": "list",
            "icon": "fas fa-chart-bar",
            "roles": ["eleve", "parent", "professeur"],
            "default_size": { "width": 2, "height": 1 },
            "min_width": 1,
            "max_width": 4,
            "is_default": true,
            "sort_order": 30,
            "data_provider": "includes/NoteWidgetProvider.php",
            "template": "widgets/dernieres_notes.php"
        }
    ],
    "establishment_types": null,
    "sidebar": { "sort_order": 10 },
    "settings_schema": {
        "lock_after_days": {
            "type": "integer",
            "default": 30,
            "label": { "fr": "Verrouiller après (jours)", "en": "Lock after (days)" }
        }
    }
}
