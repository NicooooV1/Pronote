{
    "key": "agenda",
    "version": "1.0.0",
    "name": { "fr": "Agenda", "en": "Calendar" },
    "description": { "fr": "Agenda et événements scolaires", "en": "School calendar and events" },
    "icon": "fas fa-calendar-alt",
    "category": "scolaire",
    "core": false,
    "requires_php": ">=8.0",
    "dependencies": [],
    "permissions": {
        "view": { "default_roles": ["*"] },
        "manage": { "default_roles": ["administrateur", "professeur", "vie_scolaire"] },
        "create": { "default_roles": ["administrateur", "professeur"] }
    },
    "routes": {
        "main": "agenda.php"
    },
    "widgets": [
        {
            "key": "prochains_evenements",
            "name": { "fr": "Prochains événements", "en": "Upcoming events" },
            "description": { "fr": "Événements à venir cette semaine", "en": "Events coming up this week" },
            "type": "list",
            "icon": "fas fa-calendar",
            "roles": null,
            "default_size": { "width": 2, "height": 1 },
            "min_width": 1,
            "max_width": 4,
            "is_default": true,
            "sort_order": 10,
            "data_provider": "includes/AgendaWidgetProvider.php",
            "template": "widgets/prochains_evenements.php"
        }
    ],
    "establishment_types": null,
    "sidebar": { "sort_order": 12 }
}
