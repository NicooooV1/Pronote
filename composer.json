{
  "name": "fronote/fronote",
  "description": "Fronote – Système de gestion scolaire",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "firebase/php-jwt": "^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "API\\": "API/",
      "Pronote\\": "API/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
