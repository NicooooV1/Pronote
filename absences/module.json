{
    "key": "absences",
    "version": "1.0.0",
    "name": {
        "fr": "Absences",
        "en": "Absences"
    },
    "description": {
        "fr": "Gestion des absences et retards",
        "en": "Absence and tardiness management"
    },
    "icon": "fas fa-calendar-times",
    "category": "vie_scolaire",
    "core": false,
    "requires_php": ">=8.0",
    "dependencies": [],
    "permissions": {
        "view": {
            "default_roles": [
                "*"
            ]
        },
        "manage": {
            "default_roles": [
                "administrateur",
                "vie_scolaire",
                "professeur"
            ]
        },
        "justify": {
            "default_roles": [
                "eleve",
                "parent"
            ]
        },
        "validate": {
            "default_roles": [
                "administrateur",
                "vie_scolaire"
            ]
        },
        "export": {
            "default_roles": [
                "administrateur",
                "vie_scolaire"
            ]
        }
    },
    "routes": {
        "main": "absences.php"
    },
    "widgets": [
        {
            "key": "absences_du_jour",
            "name": {
                "fr": "Absences du jour",
                "en": "Today's absences"
            },
            "description": {
                "fr": "Absences signalées aujourd'hui",
                "en": "Absences reported today"
            },
            "type": "stats",
            "icon": "fas fa-calendar-times",
            "roles": [
                "administrateur",
                "vie_scolaire",
                "professeur"
            ],
            "default_size": {
                "width": 1,
                "height": 1
            },
            "min_width": 1,
            "max_width": 2,
            "is_default": true,
            "sort_order": 50,
            "data_provider": "includes/AbsenceWidgetProvider.php",
            "template": "widgets/absences_du_jour.php"
        }
    ],
    "establishment_types": null,
    "sidebar": {
        "sort_order": 20
    },
    "author": "Fronote Team",
    "author_url": "",
    "contributors": [],
