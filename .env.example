# Exemple de configuration Fronote - Ce fichier sera généré automatiquement lors de l'installation.
# NE PAS MODIFIER MANUELLEMENT, utilisez install.php pour générer ce fichier.

# Sécurité installation
ALLOWED_INSTALL_IP=

# Base de données
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Application
APP_NAME="Fronote"
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_BASE_PATH=
BASE_URL=

# Sécurité
CSRF_LIFETIME=3600
CSRF_MAX_TOKENS=10

# Sessions
SESSION_NAME=pronote_session
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Connexion
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# Rate limiting
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_DECAY=1

# Chemins
LOGS_PATH=
UPLOADS_PATH=
TEMP_PATH=

# Mail (à configurer après installation)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Fronote"

# Timezone
APP_TIMEZONE=Europe/Paris

# Audit
AUDIT_RETENTION_DAYS=180
AUDIT_ENABLED=true

# ==================================================
# WEBSOCKET
# ==================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_URL=http://localhost:3000
WEBSOCKET_CLIENT_URL=http://localhost:3000
WEBSOCKET_API_SECRET=your_secure_secret_here
JWT_SECRET=your_jwt_secret_here

# ==================================================
# MISE À JOUR AUTOMATIQUE
# ==================================================
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_REPO=username/fronote
GITHUB_BRANCH=main

# ==================================================
# INTERNATIONALISATION
# ==================================================
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# ==================================================
# API EXTERNE
# ==================================================
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=60

# ==================================================
# CACHE
# ==================================================
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ==================================================
# SSO / OAUTH2
# ==================================================
OAUTH_PROVIDER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
OAUTH_SCOPES=
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

# ==================================================
# BACKUP
# ==================================================
BACKUP_RETENTION=5