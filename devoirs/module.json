            "default_size": {
                "width": 2,
                "height": 1
            },
            "is_default": true,
            "sort_order": 20,
            "data_provider": "includes/DevoirWidgetProvider.php",
            "template": "widgets/devoirs_a_faire.php"
        }
    ],
    "establishment_types": null,
    "sidebar": {
        "sort_order": 13
