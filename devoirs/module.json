{
    "key": "devoirs",
    "version": "1.0.0",
    "name": {
        "fr": "Devoirs",
        "en": "Assignments"
    },
    "description": {
        "fr": "Remise et suivi des devoirs",
        "en": "Assignment submission and tracking"
    },
    "icon": "fas fa-tasks",
    "category": "scolaire",
    "core": false,
    "permissions": {
        "view": {
            "default_roles": [
                "*"
            ]
        },
        "manage": {
            "default_roles": [
                "administrateur",
                "professeur"
            ]
        },
        "submit": {
            "default_roles": [
                "eleve"
            ]
