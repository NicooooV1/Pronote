{
    "key": "accessibilite",
    "version": "1.0.0",
    "name": {
        "fr": "Accessibilité & Inclusion",
        "en": "Accessibility & Inclusion"
    },
    "description": {
        "fr": "Registre aménagements, gestion AESH, liaison MDPH, suivi PPS/PAP et audit accessibilité numérique",
        "en": "Accommodations registry, AESH management, MDPH liaison, PPS/PAP tracking and digital accessibility audit"
    },
    "icon": "fas fa-universal-access",
    "category": "scolaire",
    "core": false,
    "requires_php": ">=8.0",
    "dependencies": ["besoins"],
    "permissions": {
        "view": { "default_roles": ["administrateur", "vie_scolaire", "professeur"] },
        "manage": { "default_roles": ["administrateur", "vie_scolaire"] },
        "consulter": { "default_roles": ["professeur", "parent"] },
        "export": { "default_roles": ["administrateur"] }
    },
    "routes": { "main": "accessibilite.php" },
    "widgets": [
        {
            "key": "accessibilite_suivi",
            "name": { "fr": "Suivi accessibilité", "en": "Accessibility tracking" },
            "description": { "fr": "Élèves avec aménagements actifs", "en": "Students with active accommodations" },
            "type": "stats",
            "icon": "fas fa-universal-access",
            "roles": ["administrateur", "vie_scolaire"],
            "default_size": { "width": 2, "height": 1 },
            "is_default": false,
            "sort_order": 76,
            "data_provider": "includes/AccessibiliteWidgetProvider.php"
        }
    ],
    "establishment_types": null,
    "sidebar": { "sort_order": 58 },
    "topbar": { "category": "scolaire", "sort_order": 58 },
    "settings_schema": {
        "notification_profs": {
            "type": "checkbox",
            "default": true,
            "label": { "fr": "Notifier les profs des aménagements", "en": "Notify teachers of accommodations" }
        },
        "audit_rgaa": {
            "type": "checkbox",
            "default": false,
            "label": { "fr": "Audit RGAA activé", "en": "RGAA audit enabled" }
        }
    },
    "author": "Fronote Team",
    "license": "MIT"
}
