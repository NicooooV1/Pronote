Options -Indexes

# Protéger les fichiers sensibles
<FilesMatch "(^\.env$|^install\.lock$|^composer\.lock$|^pronote\.sql$|\.bak$|\.log$)">
    Require all denied
</FilesMatch>

# Compression gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml
</IfModule>

# Cache des assets statiques
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# Headers de cache pour les fichiers statiques
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|woff|woff2)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # Pas de cache pour les fichiers PHP
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Custom error pages
ErrorDocument 403 /templates/errors/403.php
ErrorDocument 404 /templates/errors/404.php
ErrorDocument 500 /templates/errors/500.php
ErrorDocument 503 /templates/errors/503.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquer l'accès aux répertoires sensibles
    RewriteRule ^(temp|logs|vendor)(/|$) - [F,L]

    # Les endpoints API sont appelés directement (ex: API/endpoints/messagerie.php)

    # Service Worker scope
    RewriteRule ^sw\.js$ - [L]
</IfModule>
