Options -Indexes

# Protéger les fichiers sensibles
<FilesMatch "(^\.env$|^install\.lock$|^composer\.lock$|^pronote\.sql$|^diagnostic\.php$|\.bak$|\.log$)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquer l'accès aux répertoires sensibles
    RewriteRule ^(temp|logs|vendor|migrations)(/|$) - [F,L]

    # Router /api/* vers le dispatcher (uniquement si fichier/dossier inexistant)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ API/index.php [QSA,L]
</IfModule>
